# Copy this file to .env before running:
#   docker compose up -d --build

# ClearML server endpoints
CLEARML_API_HOST=http://your-clearml-host:8008
CLEARML_WEB_HOST=http://your-clearml-host:8080
CLEARML_FILES_HOST=http://your-clearml-host:8081

# ClearML credentials
CLEARML_API_ACCESS_KEY=replace-with-access-key
CLEARML_API_SECRET_KEY=replace-with-secret-key

# Optional customization
# CLEARML_AGENT_IMAGE=table-analysis-clearml-agent:latest
# CLEARML_DOCKER_NETWORK=docker_backend
